{
    "comments": {
        "lineComment": "!!!"
    },
    "brackets": [
        ["{", "}"]
    ],
    "autoClosingPairs": [
        { "open": "{", "close": "}" },
        { "open": "\"", "close": "\"" }
    ],
    "surroundingPairs": [
        ["{", "}"],
        ["\"", "\""]
    ],
    "colorizedBracketPairs": [
        ["{", "}"]
    ],
    "indentationRules": {
        "increaseIndentPattern": "^.*\\{\\s*$",
        "decreaseIndentPattern": "^\\s*\\}.*$"
    }
}